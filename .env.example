# Shared team secret: HMAC for /api/webhook + X-Team-Secret header for
# /api/heartbeat and /api/state. Generate: openssl rand -hex 32
# Must equal the TEAM_HEARTBEAT_SECRET used by scripts/repo-init.sh.
TEAM_HEARTBEAT_SECRET=

# Injected by the Vercel Marketplace Upstash integration on deploy.
# For local dev, copy from the Upstash console (KV_REST_API_* also accepted).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional read-only token (Issues + Pull requests read on the team repo).
# With it the lazy reconcile runs at 60s staleness; without it, 5 minutes.
GITHUB_TOKEN=

# Optional owner/repo override. Normally learned from the first webhook.
GITHUB_REPO=
